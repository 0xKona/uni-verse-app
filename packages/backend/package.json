{
  "name": "uni-verse-backend",
  "version": "0.1.0",
  "description": "CDK Backend for Uni-Verse application",
  "private": true,
  "bin": {
    "backend": "bin/backend.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "cdk deploy --all",
    "deploy:dev": "cdk deploy --all --context environment=dev --require-approval never",
    "deploy:prod": "cdk deploy --all --context environment=prod --require-approval=broadest",
    "destroy": "cdk destroy --all",
    "destroy:dev": "cdk destroy --all --context environment=dev --force",
    "destroy:prod": "cdk destroy --all --context environment=prod"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1109.0",
    "esbuild": "^0.27.4",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-translate": "^3.1019.0",
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.5.0"
  }
}

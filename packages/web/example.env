# Cognito Auth
NEXT_PUBLIC_COGNITO_USER_POOL_ID=<FROM CDK DEPLOYMENT OUTPUTS>
NEXT_PUBLIC_COGNITO_CLIENT_ID=<FROM CDK DEPLOYMENT OUTPUTS>
COGNITO_REGION=eu-west-2

# AppSync
NEXT_PUBLIC_APPSYNC_URL=<FROM CDK DEPLOYMENT OUTPUTS>
NEXT_PUBLIC_AWS_REGION=eu-west-2

# S3 Media Bucket (public base URL, e.g. https://<bucket>.s3.<region>.amazonaws.com)
NEXT_PUBLIC_MEDIA_BUCKET_URL=<FROM CDK DEPLOYMENT OUTPUTS>

# Giphy API Key
NEXT_PUBLIC_GIPHY_API_KEY=<API-KEY>
{
  "name": "uni-verse-app",
  "version": "1.0.0",
  "private": true,
  "description": "Uni-Verse monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=uni-verse-frontend-web",
    "build:web": "npm run build --workspace=uni-verse-frontend-web",
    "dev:backend": "npm run dev --workspace=uni-verse-backend",
    "build:backend": "npm run build --workspace=uni-verse-backend",
    "deploy:backend:dev": "npm run deploy:dev --workspace=uni-verse-backend",
    "deploy:backend:prod": "npm run deploy:prod --workspace=uni-verse-backend",
    "deploy:backend": "npm run deploy --workspace=uni-verse-backend",
    "destroy:backend": "npm run destroy --workspace=uni-verse-backend",
    "destroy:backend:dev": "npm run destroy:dev --workspace=uni-verse-backend",
    "destroy:backend:prod": "npm run destroy:prod --workspace=uni-verse-backend"
  }
}
